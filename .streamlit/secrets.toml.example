# .streamlit/secrets.toml.example
# ══════════════════════════════════════════════════════════════
# CRISPR Target Finder — Secrets Configuration
# ══════════════════════════════════════════════════════════════
# Copy this file to .streamlit/secrets.toml and fill in values.
# NEVER commit secrets.toml to git!
# ══════════════════════════════════════════════════════════════

# ── Google OAuth (optional) ──────────────────────────────────
# How to get credentials (3 min):
# 1. Go to https://console.cloud.google.com
# 2. Create project → APIs & Services → Credentials
# 3. "Create Credentials" → OAuth 2.0 Client ID
# 4. Application type: Web application
# 5. Authorized redirect URIs:
#      - http://localhost:8501       (local dev)
#      - https://your-app.streamlit.app  (Streamlit Cloud)
# 6. Copy Client ID and Secret below

[google_oauth]
client_id     = "YOUR_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_CLIENT_SECRET"
redirect_uri  = "http://localhost:8501"

# ── App secrets ──────────────────────────────────────────────
[app]
secret_key    = "change-me-to-a-long-random-string-abc123xyz"
cookie_expiry = 7   # days

# ── Optional: Pre-authorized emails for auto-approve signups ─
[preauthorized]
emails = [
    "researcher@university.edu",
    "collaborator@biotech.com",
]
